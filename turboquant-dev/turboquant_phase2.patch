+    for (int64_t b = 0; b < nb; b++) {
+        memcpy(buf, x + b * QK_TURBO, sizeof(buf));
+
+        turbo_sign_flip(buf, QK_TURBO, TURBO_SIGN_SEED);
+        turbo_fwht_inplace(buf, QK_TURBO);
