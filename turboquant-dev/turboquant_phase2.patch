+        for (int i = 0; i < QK_TURBO; i += 2) {
+            uint8_t byte = x[b].qs[i / 2];
+            out[i]     = turbo4_codebook[byte & 0x0F] * d;
+            out[i + 1] = turbo4_codebook[byte >> 4]    * d;
+        }
+        turbo_fwht_inplace(out, QK_TURBO);
+        turbo_sign_flip(out, QK_TURBO, TURBO_SIGN_SEED);
+    }
+}
